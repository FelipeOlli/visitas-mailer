# Banco de dados (banco "mailer" no mesmo Postgres do visitas-v2)
DATABASE_URL=postgresql://postgres:senha@visitasrj-db:5432/mailer

# Auth (gere com: openssl rand -base64 32)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://mailer.seudominio.com

# n8n webhook para disparar campanhas
N8N_WEBHOOK_URL=https://n8n.seudominio.com/webhook/disparar-campanha

# Segredo para endpoint de cadastro único de usuário
REGISTER_SECRET=
